{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CORS": {
    "AllowedOrigins": [ "http://localhost:3000", "https://localhost:3000" ],
    "AllowedHeaders": [],
    "AllowedMethods": []
  },
  "ConnectionStrings": {
    "DefaultConnection": "connection_string"
  },
  "Jwt": {
    "Key": "NiceSecretKey",
    "Issuer": "StreetcodeAuth",
    "Audience": "StreetcodeClient",
    "ExpireMinutes": "SomeTime",
    "RefreshTokenExpireDays": "SomeTime"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Username": "SomeUsername",
    "Password": "SomePassword"
  },
  "Admin": {
    "Email": "admin@streetcode.com",
    "Password": "SomePassword"
  }, 
    "Authentication": {
    "Google": {
      "ClientId": "clientID",
      "ClientSecret": "clientSecret"
    }
  }
 }